---
import Base from '../layouts/Base.astro'
import PricingCards from '../components/PricingCards'

const APP_URL = 'https://app.cowork-claw.ai'

const AGENTS = ['Researcher', 'Copywriter', 'Analyst', 'Designer', 'Editor', 'SEO', 'Data']

const FEATURES = [
  {
    title: 'AI Team, Not a Chatbot',
    description: 'Multiple agents collaborate on your task — researcher, copywriter, analyst, editor — each doing what they do best.',
    icon: '🤝',
  },
  {
    title: '10 Ready-Made Templates',
    description: 'Pitch decks, prospecting pipelines, proposals, research briefs, content repurposing, and more — one click to start.',
    icon: '📋',
  },
  {
    title: 'Real Deliverables',
    description: 'Download actual files — slide decks, CSV exports, branded proposals, formatted updates. Not just chat responses.',
    icon: '📦',
  },
  {
    title: 'Bring Your Own Key',
    description: 'Use your Anthropic API key. Your key, your usage, your control. Encrypted and never logged.',
    icon: '🔑',
  },
  {
    title: 'Self-Hosted & Private',
    description: 'Runs on your VPS in Docker. Your data never leaves your infrastructure.',
    icon: '🏠',
  },
  {
    title: 'Built for Founders',
    description: 'Stop doing office work yourself. Let your AI team handle the repetitive stuff while you focus on what matters.',
    icon: '🚀',
  },
]
---

<Base>
  <!-- Hero -->
  <section class="py-20 sm:py-32 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight leading-tight">
        Stop doing office work.<br />
        <span class="text-primary">Your AI team does it together.</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed">
        Pitch decks, proposals, research, outreach, hiring — describe what you need, and a team of AI agents works together to deliver it. Cowork meets OpenClaw — for founders.
      </p>
      <p class="mt-3 text-sm text-muted-foreground">
        All plans include hosted sandbox execution and bring-your-own-key support.
      </p>
      <div class="mt-8 flex items-center justify-center gap-3 flex-wrap">
        <a
          href={`${APP_URL}/api/auth/signin/github`}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-sm hover:opacity-90 transition-opacity gap-2"
        >
          Sign In with GitHub
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center justify-center rounded-md border border-border bg-background px-6 py-3 text-sm font-medium text-foreground hover:bg-accent transition-colors"
        >
          View Plans
        </a>
      </div>
    </div>
  </section>

  <!-- Agent strip -->
  <section class="py-10 border-y border-border bg-muted/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs uppercase tracking-widest text-muted-foreground mb-4">Your AI team includes</p>
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8">
        {AGENTS.map((name) => (
          <span class="text-sm font-medium text-muted-foreground">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 sm:py-28 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-12">Everything you need to ship faster</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {FEATURES.map((f) => (
          <div class="space-y-3">
            <div class="h-10 w-10 rounded-lg bg-primary/10 flex items-center justify-center text-lg">
              {f.icon}
            </div>
            <h3 class="font-semibold">{f.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="py-20 sm:py-28 px-4 sm:px-6 bg-muted/30 border-y border-border">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-4">Simple, transparent pricing</h2>
      <p class="text-center text-muted-foreground mb-12 max-w-lg mx-auto">
        Every plan includes hosted sandbox execution and bring-your-own-key support. No hidden fees.
      </p>
      <PricingCards client:load />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-28 px-4 sm:px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Ready to ship faster?</h2>
      <p class="text-muted-foreground mb-8">
        Sign in with GitHub to get started. Your first task is minutes away.
      </p>
      <a
        href={`${APP_URL}/api/auth/signin/github`}
        class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-sm hover:opacity-90 transition-opacity"
      >
        Get Started
      </a>
    </div>
  </section>
</Base>
