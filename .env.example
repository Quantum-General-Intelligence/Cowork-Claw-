# ============================================================================
# Cowork-Claw Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Required vars are marked [REQUIRED], optional vars are marked [OPTIONAL].

# ============================================================================
# INFRASTRUCTURE [REQUIRED]
# ============================================================================

# PostgreSQL connection string (Neon recommended)
# Get one free at https://neon.tech
POSTGRES_URL=

# Session encryption secret (JWE)
# Generate with: openssl rand -base64 32
JWE_SECRET=

# Token/API key encryption key (AES-256-CBC, must be exactly 64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# AUTHENTICATION [REQUIRED — at least one provider]
# ============================================================================

# Which auth providers to enable: "github", "vercel", or "github,vercel"
NEXT_PUBLIC_AUTH_PROVIDERS=github

# --- GitHub OAuth ---
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Vercel OAuth (optional, alternative to GitHub) ---
# Create at https://vercel.com/account/integrations
# Redirect URL: https://your-domain.com/api/auth/callback/vercel
# NEXT_PUBLIC_VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=

# ============================================================================
# VERCEL SANDBOX [REQUIRED for task execution]
# ============================================================================

# Vercel API token for creating sandboxes
# Create at https://vercel.com/account/tokens
SANDBOX_VERCEL_TOKEN=

# Team and project IDs for sandbox allocation
# Find in your Vercel project settings
SANDBOX_VERCEL_TEAM_ID=
SANDBOX_VERCEL_PROJECT_ID=

# ============================================================================
# AI API KEYS [OPTIONAL — users can provide their own in profile]
# ============================================================================

# Vercel AI Gateway key (recommended — routes to multiple providers)
# AI_GATEWAY_API_KEY=

# Anthropic API key (for Claude agent + OpenClaw chat)
# Get at https://console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI API key (for Codex, OpenCode agents)
# OPENAI_API_KEY=

# Google Gemini API key (for Gemini agent)
# GEMINI_API_KEY=

# Cursor API key (for Cursor agent)
# CURSOR_API_KEY=

# ============================================================================
# CONFIGURATION [OPTIONAL]
# ============================================================================

# Rate limit: max tasks + follow-ups per user per day (default: 5)
# MAX_MESSAGES_PER_DAY=5

# Max sandbox duration in minutes (default: 300 = 5 hours)
# MAX_SANDBOX_DURATION=300

# NPM token for private packages in sandboxes
# NPM_TOKEN=
