# ============================================================================
# Cowork-Claw Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Required vars are marked [REQUIRED], optional vars are marked [OPTIONAL].

# ============================================================================
# INFRASTRUCTURE [REQUIRED]
# ============================================================================

# PostgreSQL connection string (local pg in docker-compose, or Neon for dev)
POSTGRES_URL=postgres://cowork:cowork@127.0.0.1:5432/cowork

# Token/API key encryption key (AES-256-CBC, must be exactly 64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# AUTHENTICATION [REQUIRED]
# ============================================================================
# Authentication is handled by Supabase. Sign-in providers (email, Google,
# GitHub) are configured in the Supabase dashboard. For GitHub API access
# (reading/writing repos) make sure the GitHub provider is enabled in Supabase
# with the `repo` scope.

# --- Supabase ---
# Create a project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Which auth providers to show on the sign-in page.
# Comma-separated subset of: email, google, github
NEXT_PUBLIC_AUTH_PROVIDERS=email,google,github

# --- GitHub (optional) ---
# Client ID of the GitHub OAuth app Supabase is configured with. When set, the
# "Reconfigure GitHub access" action in the UI deep-links to the OAuth app's
# GitHub settings page so users can re-grant org/repo access without a full
# reconnect. If left empty the UI falls back to a full reconnect flow.
# NEXT_PUBLIC_GITHUB_CLIENT_ID=

# ============================================================================
# COMPANY VPS [REQUIRED for task execution]
# ============================================================================
# One VPS per company hosts persistent Linux accounts for every team member.
# Tasks run directly in the user's home directory (no ephemeral containers).

# Control-plane SSH connection to the VPS — the app connects as root and
# dispatches commands via `sudo -u <user>` for each team member.
SANDBOX_SSH_HOST=127.0.0.1
SANDBOX_SSH_PORT=22
SANDBOX_SSH_USER=root
# Base64-encoded PEM private key (generate: base64 -w0 ~/.ssh/cowork_deploy)
SANDBOX_SSH_KEY=

# Host directory where per-task artifacts are stored (default: /var/lib/cowork-artifacts)
ARTIFACT_ROOT=/var/lib/cowork-artifacts

# Public base URL for the web-terminal reverse proxy (ttyd), e.g.
# https://terminal.example.com — the app redirects "Log in to <CLI>" buttons here.
# TERMINAL_PROXY_URL=

# ============================================================================
# AI API KEYS [OPTIONAL — users can provide their own in profile]
# ============================================================================

# Vercel AI Gateway key (recommended — routes to multiple providers)
# AI_GATEWAY_API_KEY=

# Anthropic API key (for Claude agent + OpenClaw chat)
# Get at https://console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI API key (for Codex, OpenCode agents)
# OPENAI_API_KEY=

# Google Gemini API key (for Gemini agent)
# GEMINI_API_KEY=

# Cursor API key (for Cursor agent)
# CURSOR_API_KEY=

# ============================================================================
# BILLING — Stripe [OPTIONAL — required for paid plans]
# ============================================================================

# Stripe secret key (sk_live_... or sk_test_...)
# STRIPE_SECRET_KEY=
# or use an aliased key name:
# STRIPE_THEOSYM_SECRET_KEY=

# Stripe price IDs (create products in Stripe Dashboard or via API)
# STRIPE_HOBBY_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_STUDIO_PRICE_ID=price_...
# STRIPE_WHITELABEL_PRICE_ID=price_...

# Stripe webhook secret (whsec_...)
# STRIPE_WEBHOOK_SECRET=

# ============================================================================
# CONFIGURATION [OPTIONAL]
# ============================================================================

# Rate limit: max tasks + follow-ups per user per day (default: 5)
# MAX_MESSAGES_PER_DAY=5

# NPM token for private packages when tasks install dependencies
# NPM_TOKEN=
